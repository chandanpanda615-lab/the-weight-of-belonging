---
interface Props {
  title: string;
  description?: string;
  image?: string;
}

const {
  title,
  description = "A village in Kandhamal. An invitation to stay.",
  image = "photos/01-river-fisherman.jpeg",
} = Astro.props;

const currentPath = Astro.url.pathname;
const base = import.meta.env.BASE_URL;
const basePath = base.endsWith("/") ? base : `${base}/`;
const pathFor = (path = "") => `${basePath}${path.replace(/^\/+/, "")}`;
const fullTitle = `${title} — The Weight of Belonging`;
const siteUrl = Astro.site ?? new URL("https://chandanpanda615-lab.github.io");
const canonicalURL = new URL(Astro.url.pathname, siteUrl).toString();
const imageURL = new URL(pathFor(image), siteUrl).toString();
const isHome = currentPath === base || currentPath === basePath;
const isDispatch = currentPath.startsWith(pathFor("dispatch"));
---
<!doctype html>
<html lang="en">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <title>{fullTitle}</title>
  <meta name="description" content={description} />
  <link rel="canonical" href={canonicalURL} />
  <link rel="icon" type="image/svg+xml" href={pathFor("favicon.svg")} />
  <meta property="og:type" content="website" />
  <meta property="og:site_name" content="The Weight of Belonging" />
  <meta property="og:title" content={fullTitle} />
  <meta property="og:description" content={description} />
  <meta property="og:url" content={canonicalURL} />
  <meta property="og:image" content={imageURL} />
  <meta name="twitter:card" content="summary_large_image" />
  <meta name="twitter:title" content={fullTitle} />
  <meta name="twitter:description" content={description} />
  <meta name="twitter:image" content={imageURL} />
</head>
<body>
  <a class="skip-link" href="#content">Skip to content</a>
  <div class="site-frame">
    <header class="site-header">
      <a href={pathFor()} class="brand" aria-label="The Weight of Belonging home">
        <span class="brand-primary">The Weight</span>
        <span class="brand-secondary">of Belonging</span>
      </a>
      <nav class="site-nav" aria-label="Primary navigation">
        <a href={pathFor()} aria-current={isHome ? "page" : undefined}>Letter</a>
        <a href={pathFor("dispatch")} aria-current={isDispatch ? "page" : undefined}>Dispatch</a>
        <a href="mailto:chandanpanda615@gmail.com">Write</a>
      </nav>
    </header>

    <main id="content">
      <slot />
    </main>

    <footer class="site-footer">
      <div>
        <p class="footer-kicker">Saranagada · Kandhamal · Odisha</p>
        <p class="footer-title">An invitation to arrive slowly.</p>
      </div>
      <div class="footer-links">
        <a href={pathFor()}>Letter</a>
        <a href={pathFor("dispatch")}>Dispatch</a>
        <a href="mailto:chandanpanda615@gmail.com">Write</a>
      </div>
    </footer>
  </div>
</body>
</html>

<style is:global>
  @import "../styles/global.css";
</style>
