---
import Base from "../../layouts/Base.astro";
import { getCollection } from "astro:content";
const base = import.meta.env.BASE_URL;

const issues = (await getCollection("dispatch")).sort((a, b) => {
  if (a.data.vol !== b.data.vol) return b.data.vol - a.data.vol;
  return b.data.issue - a.data.issue;
});
---
<Base title="The Dispatch" description="Dispatches from Saranagada — a village in Kandhamal, Odisha.">

<div class="dispatch-index">

  <div class="index-header">
    <div class="kicker">dispatches from saranagada · kandhamal · odisha</div>
    <h1 class="masthead-title">The Weight of Belonging</h1>
    <p class="index-note">Essays written from a desk in Bangalore about a village I left and intend to return to. New issues when there is something worth saying.</p>
  </div>

  <hr class="rule" />

  <div class="issue-list">
    {issues.map((issue) => (
      <a href={`/dispatch/${issue.id}`} class="issue-card">
        <div class="issue-meta">
          <span class="vol-issue">Vol. {issue.data.vol} · No. {issue.data.issue}</span>
          <span class="date">{issue.data.date}</span>
        </div>
        <div class="issue-photo">
          <img src={`${base}${issue.data.heroPhoto.replace(/^\//, '')}`} alt={issue.data.heroAlt} />
        </div>
        <div class="issue-text">
          <h2 class="issue-title">{issue.data.title}</h2>
          <p class="issue-lede">{issue.data.lede}</p>
          <span class="read-link">read →</span>
        </div>
      </a>
    ))}
  </div>

  <div class="subscribe-note">
    <div class="kicker">stay in touch</div>
    <p>No newsletter signup. If you would like to know when new dispatches appear, <a href="mailto:chandanpanda615@gmail.com?subject=Please%20let%20me%20know%20when%20you%20write">write to me</a> and I will write to you.</p>
  </div>

</div>

</Base>

<style>
.dispatch-index { max-width: 760px; margin: 0 auto; }

.index-header { margin-bottom: 32px; }
.kicker {
  font-family: var(--mono);
  font-size: var(--fs-xxs);
  letter-spacing: 0.16em;
  text-transform: uppercase;
  color: var(--accent);
  margin-bottom: 10px;
}
.masthead-title {
  font-family: var(--serif);
  font-size: var(--fs-2xl);
  font-weight: 500;
  letter-spacing: -0.01em;
  margin: 0 0 12px;
  line-height: 1.1;
}
.index-note {
  font-size: var(--fs-md);
  color: var(--ink-soft);
  max-width: 55ch;
  line-height: 1.6;
  margin: 0;
}

.issue-list { display: flex; flex-direction: column; gap: 0; }

.issue-card {
  display: grid;
  grid-template-columns: 160px 1fr;
  grid-template-rows: auto 1fr;
  gap: 0 20px;
  padding: 28px 0;
  border-bottom: 1px solid var(--rule);
  text-decoration: none;
  transition: background 0.1s;
}
.issue-card:hover { text-decoration: none; }
.issue-card:hover .issue-title { color: var(--accent); }

.issue-meta {
  grid-column: 1 / -1;
  display: flex;
  gap: 16px;
  font-family: var(--mono);
  font-size: var(--fs-xxs);
  letter-spacing: 0.12em;
  text-transform: uppercase;
  color: var(--ink-faint);
  margin-bottom: 14px;
}

.issue-photo {
  grid-column: 1;
  aspect-ratio: 4/3;
  overflow: hidden;
  background: var(--paper-edge);
}
.issue-photo img {
  width: 100%;
  height: 100%;
  object-fit: cover;
  transition: transform 0.3s ease;
}
.issue-card:hover .issue-photo img { transform: scale(1.03); }

.issue-text { grid-column: 2; }
.issue-title {
  font-size: var(--fs-lg);
  font-weight: 500;
  margin: 0 0 10px;
  line-height: 1.25;
  transition: color 0.15s;
}
.issue-lede {
  font-size: var(--fs-sm);
  color: var(--ink-soft);
  line-height: 1.6;
  margin: 0 0 12px;
}
.read-link {
  font-family: var(--mono);
  font-size: var(--fs-xxs);
  letter-spacing: 0.1em;
  text-transform: uppercase;
  color: var(--accent);
}

.subscribe-note {
  margin-top: 48px;
  padding: 24px 0;
  border-top: 2px solid var(--ink);
  font-size: var(--fs-sm);
  color: var(--ink-soft);
}
.subscribe-note a { color: var(--accent); text-decoration: underline; }

@media (max-width: 520px) {
  .issue-card { grid-template-columns: 1fr; }
  .issue-photo { aspect-ratio: 16/7; margin-bottom: 14px; }
  .issue-text { grid-column: 1; }
  .masthead-title { font-size: var(--fs-xl); }
}
</style>
