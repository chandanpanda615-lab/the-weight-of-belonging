---
import Base from "../../layouts/Base.astro";
import { getCollection } from "astro:content";

const base = import.meta.env.BASE_URL;
const basePath = base.endsWith("/") ? base : `${base}/`;
const pathFor = (path = "") => `${basePath}${path.replace(/^\/+/, "")}`;

const issues = (await getCollection("dispatch")).sort((a, b) => {
  if (a.data.vol !== b.data.vol) return b.data.vol - a.data.vol;
  return b.data.issue - a.data.issue;
});
const latest = issues[0];
---
<Base
  title="The Dispatch"
  description="Field notes and essays from Saranagada, Kandhamal, Odisha."
  image={latest?.data.heroPhoto ?? "photos/06-group-road.jpeg"}
>
  <section class="dispatch-hero full-bleed">
    <div class="dispatch-hero-inner">
      <p class="eyebrow">Dispatches from Saranagada</p>
      <h1>Notes from the place I left and intend to return to.</h1>
      <p>
        Essays written from a desk in Bangalore about a village that keeps asking
        better questions than the city does.
      </p>
    </div>
  </section>

  <section class="dispatch-index">
    {latest && (
      <a class="featured-issue" href={pathFor(`dispatch/${latest.id}`)}>
        <div class="featured-copy">
          <p class="meta-line">Latest · Vol. {latest.data.vol} · No. {latest.data.issue}</p>
          <h2>{latest.data.title}</h2>
          <p>{latest.data.lede}</p>
          <span class="text-link">Read the essay</span>
        </div>
        <figure class="media-frame">
          <img src={pathFor(latest.data.heroPhoto)} alt={latest.data.heroAlt} />
        </figure>
      </a>
    )}

    <div class="issue-list" aria-label="All dispatches">
      {issues.map((issue) => (
        <a href={pathFor(`dispatch/${issue.id}`)} class="issue-card">
          <figure>
            <img src={pathFor(issue.data.heroPhoto)} alt={issue.data.heroAlt} />
          </figure>
          <div>
            <p class="meta-line">Vol. {issue.data.vol} · No. {issue.data.issue} · {issue.data.date}</p>
            <h2>{issue.data.title}</h2>
            <p>{issue.data.lede}</p>
          </div>
        </a>
      ))}
    </div>

    <div class="dispatch-note">
      <p class="section-kicker">Stay in touch</p>
      <p>No newsletter signup. If you would like to know when new dispatches appear, write to me and I will write to you.</p>
      <a class="text-link" href="mailto:chandanpanda615@gmail.com?subject=Please%20let%20me%20know%20when%20you%20write">Write to me</a>
    </div>
  </section>
</Base>

<style>
.dispatch-hero {
  background:
    linear-gradient(135deg, rgba(16, 38, 31, 0.95), rgba(47, 111, 115, 0.88)),
    var(--forest);
  color: var(--paper-soft);
}

.dispatch-hero-inner {
  width: min(1180px, calc(100% - 40px));
  margin: 0 auto;
  padding: 86px 0 72px;
}

.dispatch-hero h1 {
  max-width: 930px;
  margin-bottom: 18px;
  font-size: 56px;
  line-height: 1;
  font-weight: 500;
}

.dispatch-hero p:not(.eyebrow) {
  max-width: 620px;
  color: rgba(255, 250, 240, 0.82);
  font-size: var(--fs-lg);
}

.dispatch-index {
  display: flex;
  flex-direction: column;
  gap: 54px;
  margin-top: 64px;
}

.featured-issue {
  display: grid;
  grid-template-columns: minmax(0, 0.86fr) minmax(340px, 1fr);
  gap: 42px;
  align-items: stretch;
  padding-bottom: 54px;
  border-bottom: 1px solid var(--line-strong);
}

.featured-copy {
  display: flex;
  flex-direction: column;
  justify-content: center;
}

.featured-copy h2 {
  margin-bottom: 16px;
  font-size: var(--fs-2xl);
  line-height: 1.12;
  font-weight: 500;
  color: var(--forest-deep);
}

.featured-copy p:not(.meta-line) {
  color: var(--ink-soft);
}

.featured-issue .media-frame {
  aspect-ratio: 16 / 10;
}

.issue-list {
  display: grid;
  grid-template-columns: repeat(2, minmax(0, 1fr));
  gap: 18px;
}

.issue-card {
  display: grid;
  grid-template-columns: 150px 1fr;
  gap: 20px;
  min-height: 190px;
  padding: 18px;
  border: 1px solid var(--line);
  background: rgba(255, 250, 240, 0.62);
}

.issue-card:hover {
  border-color: var(--soil);
  background: rgba(255, 250, 240, 0.88);
}

.issue-card figure {
  margin: 0;
  overflow: hidden;
  background: var(--mist);
}

.issue-card img {
  width: 100%;
  height: 100%;
  object-fit: cover;
  transition: transform 0.35s ease;
}

.issue-card:hover img {
  transform: scale(1.04);
}

.issue-card h2 {
  margin-bottom: 8px;
  font-size: var(--fs-lg);
  line-height: 1.2;
  color: var(--forest);
}

.issue-card p:not(.meta-line) {
  margin-bottom: 0;
  color: var(--ink-soft);
  font-size: var(--fs-sm);
}

.dispatch-note {
  max-width: 640px;
  padding-top: 26px;
  border-top: 1px solid var(--line-strong);
}

@media (max-width: 860px) {
  .dispatch-hero h1 {
    font-size: var(--fs-2xl);
  }

  .dispatch-hero p:not(.eyebrow) {
    font-size: var(--fs-md);
  }

  .featured-issue,
  .issue-list {
    grid-template-columns: 1fr;
  }

  .issue-card {
    grid-template-columns: 130px 1fr;
  }
}

@media (max-width: 560px) {
  .dispatch-hero-inner {
    width: min(100% - 28px, 1180px);
    padding: 64px 0 56px;
  }

  .issue-card {
    grid-template-columns: 1fr;
  }

  .issue-card figure {
    aspect-ratio: 16 / 9;
  }
}
</style>
